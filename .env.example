# OpenAI Settings
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-3-small

# Pinecone Settings
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=chatbot-index

# Security (X-API-Key validation)
API_KEY_SECRET=your_static_secret_key_for_clients

# Monitoring & Logging
SENTRY_DSN=
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=*
