# OpenAI Settings
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-3-small

# Pinecone Settings
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=chatbot-index

# Security (X-API-Key validation)
API_KEY_SECRET=your_static_secret_key_for_clients

# Monitoring & Logging
SENTRY_DSN=
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=*

# Contact Links
TELEGRAM_CONTACT_URL=https://t.me/d_dreams_chatbot
VIBER_CONTACT_URL=viber://pa?chatURI=digitaldreams

# Telegram Topics
TELEGRAM_TOPIC_GENERAL=1
TELEGRAM_TOPIC_LEADS=14
TELEGRAM_TOPIC_HOT_LEADS=3
TELEGRAM_TOPIC_CONVERSIONS=11
TELEGRAM_TOPIC_BOT_STATS=17
TELEGRAM_TOPIC_PRICES=9
TELEGRAM_TOPIC_ERRORS=7
